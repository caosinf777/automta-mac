# Variables de entorno para AutoMTA Mac
# Copia este archivo a .env y completa los valores

# URL de la API de AutoMTA
# Producción:
VITE_API_URL=https://api.automta.au/api
# Desarrollo local:
# VITE_API_URL=http://localhost:3001/api

# Tu API Key de AutoMTA
# La encuentras en: automta.au → Settings → API Keys
VITE_API_KEY=your-api-key-here

# Entorno
NODE_ENV=production
